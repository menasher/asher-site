{
  "name": "asher-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "velite build",
    "dev": "next dev",
    "prebuild": "velite build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "kill": "( lsof -ti :3000 | xargs kill -9 2>/dev/null ; pkill -9 -f 'next dev' 2>/dev/null ; pkill -9 -f next-server 2>/dev/null ; true ) ; echo cleared",
    "content": "velite",
    "content:watch": "velite --watch",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\""
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
